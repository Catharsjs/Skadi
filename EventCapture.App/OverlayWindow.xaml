<Window x:Class="EventCapture.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="220"
        Height="68"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        IsHitTestVisible="False">

    <Grid VerticalAlignment="Center">
        <StackPanel VerticalAlignment="Center">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowSystemInfo}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <TextBlock Text="{Binding Cpu}"
                   FontFamily="Segoe UI"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource PrimaryTextBrush}"
                   Margin="0,1"/>

            <TextBlock Text="{Binding Gpu}"
                   FontFamily="Segoe UI"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource PrimaryTextBrush}"
                   Margin="0,1"/>

            <TextBlock Text="{Binding Ram}"
                   FontFamily="Segoe UI"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource PrimaryTextBrush}"
                   Margin="0,1"/>
        </StackPanel>

        <TextBlock Text="{Binding RecordingTime}"
                   FontFamily="Segoe UI"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource PrimaryTextBrush}"
                   VerticalAlignment="Top">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowTimer}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </Grid>
</Window>

<Window x:Class="EventCapture.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="220"
        Height="68"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        IsHitTestVisible="False">

    <StackPanel VerticalAlignment="Center">

        <TextBlock Text="{Binding Cpu}"
                   FontFamily="Segoe UI"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource PrimaryTextBrush}"
                   Margin="0,1"/>

        <TextBlock Text="{Binding Gpu}"
                   FontFamily="Segoe UI"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource PrimaryTextBrush}"
                   Margin="0,1"/>

        <TextBlock Text="{Binding Ram}"
                   FontFamily="Segoe UI"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource PrimaryTextBrush}"
                   Margin="0,1"/>
    </StackPanel>
</Window>